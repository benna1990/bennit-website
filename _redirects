# Cloudflare Pages — redirects
# Oude WordPress-URLs van vóór de redesign → nieuwe pagina's (301).
# Ruimt 404's in Search Console op en behoudt eventuele link-waarde.
# Specifieke regels boven wildcards (eerste match wint).

# Contact / afspraak
/contact/                     /#contact               301
/afspraak-maken/              /#contact               301
/actie/*                      /#contact               301

# Reparatie-pagina's (nokia, iphone, sony, …)
/reparaties/                  /computer-reparatie/    301
/reparaties/*                 /computer-reparatie/    301

# Diensten / beleid
/andere-diensten/             /#diensten              301
/privacybeleid/               /privacy-policy/        301
/klachten-regeling/           /algemene-voorwaarden/  301
